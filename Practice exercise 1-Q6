#include <stdio.h>

int main()
{
    int pages[10], frames[3];
    int n, i, j;
    int fault = 0;
    int pos = 0;
    int found;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page numbers: ");
    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    // Initially all frames are empty
    for(i = 0; i < 3; i++)
        frames[i] = -1;

    printf("\nPage\tFrames\n");

    for(i = 0; i < n; i++)
    {
        found = 0;

        // Check whether page is already in memory
        for(j = 0; j < 3; j++)
        {
            if(frames[j] == pages[i])
            {
                found = 1;
                break;
            }
        }

        // If page is not present
        if(found == 0)
        {
            frames[pos] = pages[i];
            pos = (pos + 1) % 3;
            fault++;
        }

        printf("%d\t", pages[i]);

        for(j = 0; j < 3; j++)
        {
            if(frames[j] == -1)
                printf("- ");
            else
                printf("%d ", frames[j]);
        }

        printf("\n");
    }

    printf("\nTotal Page Faults = %d", fault);

    return 0;
}
