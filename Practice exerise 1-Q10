#include <stdio.h>

int main()
{
    int bt[10], wt[10];
    int n, i;
    float avg = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Burst Time:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &bt[i]);

    wt[0] = 0;

    for(i = 1; i < n; i++)
        wt[i] = wt[i-1] + bt[i-1];

    printf("\nProcess\tBurst Time\tWaiting Time\n");

    for(i = 0; i < n; i++)
    {
        printf("P%d\t%d\t\t%d\n", i+1, bt[i], wt[i]);
        avg += wt[i];
    }

    avg = avg / n;

    printf("\nAverage Waiting Time = %.2f", avg);

    return 0;
}
