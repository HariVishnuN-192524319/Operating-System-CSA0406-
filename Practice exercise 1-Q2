#include <stdio.h>
#include <unistd.h>

int main()
{
    int p1, p2;

    p1 = fork();

    if (p1 == 0)
    {
        printf("First Child Process ID: %d\n", getpid());
    }
    else
    {
        p2 = fork();

        if (p2 == 0)
        {
            printf("Second Child Process ID: %d\n", getpid());
        }
        else
        {
            printf("Parent Process ID: %d\n", getpid());
        }
    }

    return 0;
}
