#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
int main() {
    int i;
    pid_t pid;
    for(i = 1; i <= 3; i++) {
        pid = fork();
        if(pid == 0) {
            // Child Process
            printf("Child %d\n", i);
            printf("PID  = %d\n", getpid());
            printf("PPID = %d\n\n", getppid());
            return 0;}
    }
    printf("Parent Process\n");
    printf("PID = %d\n", getpid());
    return 0;
}
