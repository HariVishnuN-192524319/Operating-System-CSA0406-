#include <stdio.h>

#define MAX 10

int queue[MAX];
int front = -1, rear = -1;

void enqueue(int process)
{
    if (rear == MAX - 1)
    {
        printf("Ready Queue is Full\n");
        return;
    }

    if (front == -1)
        front = 0;

    queue[++rear] = process;
}

void dequeue()
{
    if (front == -1 || front > rear)
    {
        printf("Ready Queue is Empty\n");
        return;
    }

    printf("Process %d is executed.\n", queue[front]);
    front++;
}

void display()
{
    int i;

    if (front == -1 || front > rear)
    {
        printf("Ready Queue is Empty\n");
        return;
    }

    printf("Ready Queue: ");

    for (i = front; i <= rear; i++)
        printf("P%d ", queue[i]);

    printf("\n");
}

int main()
{
    enqueue(1);
    enqueue(2);
    enqueue(3);

    display();

    dequeue();

    display();

    return 0;
}
