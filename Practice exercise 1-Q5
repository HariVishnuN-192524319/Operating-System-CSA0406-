#include <stdio.h>

int main()
{
    FILE *fp;
    char data[100];

    fp = fopen("sample.txt", "w");
    fprintf(fp, "Hello Operating System");
    fclose(fp);

    fp = fopen("sample.txt", "r");
    fgets(data, sizeof(data), fp);
    fclose(fp);

    printf("Data Read: %s\n", data);

    return 0;
}
