#include <stdio.h>
#include <pthread.h>

void *odd(void *arg)
{
    int i;
    for(i = 1; i <= 10; i += 2)
        printf("%d\n", i);

    return NULL;
}

void *even(void *arg)
{
    int i;
    for(i = 2; i <= 10; i += 2)
        printf("%d\n", i);

    return NULL;
}

int main()
{
    pthread_t t1, t2;

    pthread_create(&t1, NULL, odd, NULL);
    pthread_create(&t2, NULL, even, NULL);

    pthread_join(t1, NULL);
    pthread_join(t2, NULL);

    return 0;
}
