#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid;

    // Create a child process
    pid = fork();

    if (pid < 0) {
        printf("Fork failed.\n");
        return 1;
    }
    else if (pid == 0) {
        // Child process
        printf("Executing 'ls -l' command...\n");

        // Execute the ls -l command
        execlp("ls", "ls", "-l", NULL);

        // This line executes only if execlp() fails
        perror("execlp failed");
        exit(1);
    }
    else {
        // Parent process
        wait(NULL);   // Wait for child to finish
        printf("Child process completed.\n");
    }

    return 0;
}
